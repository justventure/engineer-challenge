{
  "name": "@pages/recovery-sent",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/pages/recovery-sent/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "tsc -p tsconfig.json && rsync -av --include '*/' --include '*.scss' --exclude '*' src/ dist/",
        "cwd": "packages/pages/recovery-sent"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.json --noEmit",
        "cwd": "packages/pages/recovery-sent"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rm -rf dist",
        "cwd": "packages/pages/recovery-sent"
      }
    }
  }
}
